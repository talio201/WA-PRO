{
  "name": "EmidiaWhats",
  "version": "0.0.1",
  "manifest_version": 3,
  "description": "Extrai contatos BR (+55) do WhatsApp Web e gera texto para envio em massa (anti-ban).",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "EmidiaWhats Dashboard"
  },
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "js/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "js/wapi.js",
        "inject/initFrame.js"
      ],
      "matches": [
        "https://web.whatsapp.com/*"
      ]
    }
  ]
}
