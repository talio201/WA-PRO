{
    "manifest_version": 3,
    "name": "WhatsApp Campaign Manager",
    "version": "1.0",
    "description": "Automação humana de controle de campanhas para WhatsApp.",
    "permissions": [
        "alarms",
        "storage",
        "tabs",
        "clipboardWrite",
        "clipboardRead"
    ],
    "host_permissions": [
        "*://web.whatsapp.com/*",
        "http://*/*",
        "https://*/*"
    ],
    "content_scripts": [
        {
            "matches": ["*://web.whatsapp.com/*"],
            "js": ["src/content/contentScript.js"],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "service_worker": "src/background/index.js",
        "type": "module"
    },
    "action": {
        "default_popup": "index.html",
        "default_title": "Campaign Manager"
    },
    "options_page": "options.html"
}
