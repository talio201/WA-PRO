[Unit]
Description=EmidiaWhats Backend
After=network.target

[Service]
Type=simple
User=node
Group=node
WorkingDirectory=/opt/emidiawhats/current/backend
Environment=NODE_ENV=production
EnvironmentFile=/opt/emidiawhats/current/backend/.env.production
ExecStart=/usr/bin/node src/server.js
Restart=always
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
